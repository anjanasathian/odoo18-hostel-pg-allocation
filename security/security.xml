<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="module_category_hostel_allocation" model="ir.module.category">
            <field name="name">Hostel Allocation</field>
            <field name="description">Manage hostels, rooms, tenants and allocations</field>
            <field name="sequence">35</field>
        </record>

        <record id="group_hostel_user" model="res.groups">
            <field name="name">Hostel User</field>
            <field name="category_id" ref="hostel_allocation.module_category_hostel_allocation"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_hostel_manager" model="res.groups">
            <field name="name">Hostel Manager</field>
            <field name="category_id" ref="hostel_allocation.module_category_hostel_allocation"/>
            <field name="implied_ids" eval="[(4, ref('hostel_allocation.group_hostel_user'))]"/>
        </record>

        <record id="group_hostel_admin" model="res.groups">
            <field name="name">Hostel Administrator</field>
            <field name="category_id" ref="hostel_allocation.module_category_hostel_allocation"/>
            <field name="implied_ids" eval="[(4, ref('hostel_allocation.group_hostel_manager'))]"/>
        </record>
    </data>
</odoo>
