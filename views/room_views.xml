<?xml version="1.0" encoding="utf-8"?>
<odoo>
        <!-- Room List View  -->
    <record id="view_room_list" model="ir.ui.view">
        <field name="name">hostel.room.list</field>
        <field name="model">hostel.room</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="hostel_id"/>
                <field name="floor"/>
                <field name="capacity"/>
                <field name="occupied_bed_count"/>
                <field name="available_bed_count"/>
                <field name="status"/>
            </list>
        </field>
    </record>   

    <!-- Room Form View  -->
    <record id="view_room_form" model="ir.ui.view">
        <field name="name">hostel.room.form</field>
        <field name="model">hostel.room</field>
        <field name="arch" type="xml">              
            <form string="Room">
                <sheet>
                    <group>
                        <group>
                            <field name="name" readonly="1"/>
                            <field name="hostel_id"/>
                            <field name="floor"/>
                        </group>
                        <group>
                            <field name="capacity"/>
                            <field name="status" readonly="1"/>
                        </group>
                    </group>

                    <group string="Bed Statistics">
                        <field name="bed_count" readonly="1"/>
                        <field name="occupied_bed_count" readonly="1"/>
                        <field name="available_bed_count" readonly="1"/>
                    </group>

                    <notebook>
                        <page string="Beds">
                            <field name="bed_ids">
                                <list editable="bottom">
                                    <field name="name" readonly="1"/>
                                    <field name="status"/>
                                    <field name="tenant_id"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Room Kanban View   -->
    <record id="view_hostel_room_kanban" model="ir.ui.view">
        <field name="name">hostel.room.kanban</field>
        <field name="model">hostel.room</field>
        <field name="arch" type="xml">
            <kanban>
                <field name="name"/>
                <field name="hostel_id"/>
                <field name="floor"/>
                <field name="capacity"/>
                <field name="occupied_bed_count"/>
                <field name="available_bed_count"/>
                <field name="status"/>

                <templates>
                    <t t-name="card">
                        <div class="o_kanban_record">
                            <div class="o_kanban_record_head">
                                <strong>
                                    <field name="name"/>
                                </strong>
                            </div>
                            <div>Hostel: <field name="hostel_id"/></div>
                            <div>Floor: <field name="floor"/></div>
                            <div>Capacity: <field name="capacity"/></div>
                            <div>Total Beds: <field name="bed_count"/></div>
                            <div>Occupied Beds: <field name="occupied_bed_count"/></div>
                            <div>Available Beds: <field name="available_bed_count"/></div>
                            <div>Status: <field name="status"/></div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>   

        <!-- Action -->
    <record id="action_hostel_room" model="ir.actions.act_window">
        <field name="name">Rooms</field>
        <field name="res_model">hostel.room</field>
        <field name="view_mode">list,form,kanban</field>
    </record>  
</odoo>  