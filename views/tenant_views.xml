<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tenant List View -->
    <record id="view_tenant_list" model="ir.ui.view">
        <field name="name">hostel.tenant.list</field>
        <field name="model">hostel.tenant</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="tenant_id"/>
                <field name="room_id"/>
                <field name="bed_id"/>
                <field name="check_in_date"/>
                <field name="check_out_date"/>
                <field name="booking_status" optional="show"/>
                <field name="payment_status" optional="show"/>
                <field name="status"/>
            </list>
        </field>
    </record>

    <!-- Tenant Form View -->
    <record id="view_tenant_form" model="ir.ui.view">
        <field name="name">hostel.tenant.form</field>
        <field name="model">hostel.tenant</field>
        <field name="arch" type="xml">
            <form string="Tenant">
                <header>
                    <button name="action_approve_booking" string="Approve Booking" type="object"
                            class="btn-success"
                            invisible="booking_status != 'submitted'"/>
                    <button name="action_reject_booking" string="Reject Booking" type="object"
                            class="btn-danger"
                            invisible="booking_status not in ('submitted', 'approved')"/>
                    <button name="action_check_out" string="Check Out" type="object"
                            class="btn-primary"
                            invisible="status == 'inactive' or booking_status not in ('approved', 'draft')"/>
                    <field name="booking_status" widget="statusbar"
                           statusbar_visible="draft,submitted,approved,rejected"
                           invisible="booking_source != 'website'"/>
                    <field name="status" widget="statusbar" statusbar_visible="active,inactive"
                           invisible="booking_source == 'website'"/>
                </header>
                <sheet>
                    <!-- Smart Buttons -->
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_invoice"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-file-text-o"
                                invisible="invoice_count == 0">
                            <field name="invoice_count" widget="statinfo" string="Invoice"/>
                        </button>
                    </div>

                    <field name="invoice_id" invisible="1"/>

                    <group>
                        <!-- Personal Information -->
                        <group string="Personal Information">
                            <field name="name"/>
                            <field name="tenant_id" readonly="1"/>
                            <field name="gender"/>
                            <field name="date_of_birth"/>
                            <field name="age" readonly="1"/>
                            <field name="phone"/>
                            <field name="email"/>
                            <field name="address"/>
                        </group>

                        <!-- Emergency Contact -->
                        <group string="Emergency Contact">
                            <field name="emergency_contact"/>
                            <field name="emergency_phone"/>
                        </group>
                    </group>

                    <group>
                        <!-- Allocation Details -->
                        <group string="Allocation Details">
                            <field name="hostel_id"/>
                            <field name="category_id" readonly="1"/>
                            <field name="room_id"
                                   domain="[('hostel_id', '=', hostel_id), ('status', '=', 'available')]"/>
                            <field name="bed_id"
                                   domain="[('room_id', '=', room_id), ('status', '=', 'available')]"/>
                            <field name="check_in_date"/>
                            <field name="check_out_date"/>
                        </group>

                        <!-- Mess & Facilities -->
                        <group string="Mess &amp; Facilities">
                            <field name="mess_id"
                                   domain="[('hostel_id', '=', hostel_id), ('active', '=', True)]"/>
                            <field name="mess_price" readonly="1"
                                   invisible="not mess_id"/>
                            <field name="hostel_facility_ids"
                                   widget="many2many_tags"
                                   readonly="1"
                                   invisible="not hostel_id"/>
                        </group>
                    </group>
                    <group>
                        <!-- Booking Info -->
                        <group string="Booking Info">
                            <field name="booking_source"/>
                            <field name="booking_status"/>
                            <field name="payment_status"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Tenant Kanban View  -->
    <record id="view_tenant_kanban" model="ir.ui.view">
        <field name="name">hostel.tenant.kanban</field>
        <field name="model">hostel.tenant</field>
        <field name="arch" type="xml">
            <kanban>
                <field name="name"/>
                <field name="tenant_id"/>
                <field name="gender"/>
                <field name="room_id"/>
                <field name="bed_id"/>
                <field name="mess_id"/>
                <field name="check_in_date"/>
                <field name="check_out_date"/>
                <field name="status"/>

                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_card">
                            <strong><field name="name"/></strong><br/>
                            <span>Tenant ID: <field name="tenant_id"/></span><br/>
                            <span>Gender: <field name="gender"/></span><br/>
                            <span>Room: <field name="room_id"/></span><br/>
                            <span>Bed: <field name="bed_id"/></span><br/>
                            <span>Mess: <field name="mess_id"/></span><br/>
                            <span>Check-in: <field name="check_in_date"/></span><br/>
                            <span>Check-out: <field name="check_out_date"/></span><br/>
                            <span>Status: <field name="status"/></span>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Tenant Search View -->
    <record id="view_tenant_search" model="ir.ui.view">
        <field name="name">hostel.tenant.search</field>
        <field name="model">hostel.tenant</field>
        <field name="arch" type="xml">
            <search string="Search Tenants">
                <field name="name"/>
                <field name="tenant_id"/>
                <field name="hostel_id"/>
                <field name="room_id"/>
                <field name="mess_id" string="Mess Plan"/>
                <field name="category_id" string="Category"/>
                <separator/>
                <filter string="Active" name="filter_active" domain="[('status', '=', 'active')]"/>
                <filter string="Checked Out" name="filter_checked_out" domain="[('status', '=', 'inactive')]"/>
                <separator/>
                <filter string="Male" name="filter_male" domain="[('gender', '=', 'male')]"/>
                <filter string="Female" name="filter_female" domain="[('gender', '=', 'female')]"/>
                <separator/>
                <filter string="With Mess Plan" name="filter_mess" domain="[('mess_id', '!=', False)]"/>
                <filter string="Website Bookings" name="filter_website" domain="[('booking_source', '=', 'website')]"/>
                <filter string="Pending Approval" name="filter_submitted" domain="[('booking_status', '=', 'submitted')]"/>
                <group expand="0" string="Group By">
                    <filter string="Hostel" name="group_hostel" context="{'group_by': 'hostel_id'}"/>
                    <filter string="Category" name="group_category" context="{'group_by': 'category_id'}"/>
                    <filter string="Status" name="group_status" context="{'group_by': 'status'}"/>
                    <filter string="Gender" name="group_gender" context="{'group_by': 'gender'}"/>
                    <filter string="Mess Plan" name="group_mess" context="{'group_by': 'mess_id'}"/>
                    <filter string="Booking Status" name="group_booking" context="{'group_by': 'booking_status'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action for Tenant -->
    <record id="action_hostel_tenant" model="ir.actions.act_window">
        <field name="name">Hostel Tenants</field>
        <field name="res_model">hostel.tenant</field>
        <field name="view_mode">list,form,kanban</field>
        <field name="search_view_id" ref="view_tenant_search"/>
    </record>

    <!-- Website Bookings Action -->
    <record id="action_hostel_website_bookings" model="ir.actions.act_window">
        <field name="name">Website Bookings</field>
        <field name="res_model">hostel.tenant</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('booking_source', '=', 'website')]</field>
        <field name="context">{'default_booking_source': 'website'}</field>
        <field name="search_view_id" ref="view_tenant_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No website bookings yet.
            </p>
            <p>Bookings submitted via the website will appear here for review.</p>
        </field>
    </record>
</odoo>