<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tenant List View -->   
    <record id="view_tenant_list" model="ir.ui.view">
        <field name="name">hostel.tenant.list</field>
        <field name="model">hostel.tenant</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="tenant_id"/>
                <field name="hostel_id"/>
                <field name="room_id" domain="[('hostel_id', '=', hostel_id), ('status', '=', 'available')]"/>
                <field name="bed_id" domain="[('room_id', '=', room_id), ('status', '=', 'available')]"/>
                <field name="check_in_date"/>
                <field name="check_out_date"/>
                <field name="status"/>
            </list>
        </field>
    </record>

    <!-- Tenant Form View -->
    <record id="view_tenant_form" model="ir.ui.view">
        <field name="name">hostel.tenant.form</field>
        <field name="model">hostel.tenant</field>
        <field name="arch" type="xml">
            <form string="Tenant">
                <header>
                    <button name="action_check_out" string="Check Out" type="object" class="btn-primary" invisible="status == 'inactive'"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="tenant_id"/>
                            <field name="phone"/>
                            <field name="email"/>
                            <field name="address"/>
                            <field name="invoice_id" invisible="1"/>
                        </group>
                        <group>
                            <field name="hostel_id"/>
                            <field name="room_id" domain="[('hostel_id', '=', hostel_id), ('status', '=', 'available')]"/>
                            <field name="bed_id" domain="[('room_id', '=', room_id), ('status', '=', 'available')]"/>                            
                            <field name="check_in_date"/>
                            <field name="check_out_date"/>
                            <field name="status"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form> 
        </field>
    </record>

    <!-- Tenant Kanban View  -->
    <record id="view_tenant_kanban" model="ir.ui.view">
        <field name="name">hostel.tenant.kanban</field>
        <field name="model">hostel.tenant</field>
        <field name="arch" type="xml">
            <kanban>
                <field name="name"/>
                <field name="tenant_id"/>
                <field name="room_id"/>
                <field name="bed_id"/>
                <field name="check_in_date"/>
                <field name="check_out_date"/>
                <field name="status"/>

                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_card">
                            <strong><field name="name"/></strong><br/>
                            <span>Tenant ID: <field name="tenant_id"/></span><br/>
                            <span>Room: <field name="room_id"/></span><br/>
                            <span>Bed: <field name="bed_id"/></span><br/>
                            <span>Check-in: <field name="check_in_date"/></span><br/>
                            <span>Check-out: <field name="check_out_date"/></span><br/>
                            <span>Status: <field name="status"/></span>
                        </div>
                    </t>
                </templates>    
            </kanban>
        </field>
    </record>

    <!-- Tenant Search View -->
    <record id="view_tenant_search" model="ir.ui.view">
        <field name="name">hostel.tenant.search</field>
        <field name="model">hostel.tenant</field>
        <field name="arch" type="xml">
            <search string="Search Tenants">
                <field name="name"/>
                <field name="tenant_id"/>
                <field name="hostel_id"/>
                <field name="room_id"/>
                <separator/>
                <filter string="Active" name="filter_active" domain="[('status', '=', 'active')]"/>
                <filter string="Checked Out" name="filter_checked_out" domain="[('status', '=', 'inactive')]"/>
            </search>
        </field>
    </record>

    <!-- Action for Tenant -->
    <record id="action_hostel_tenant" model="ir.actions.act_window">
        <field name="name">Hostel Tenants</field>
        <field name="res_model">hostel.tenant</field>
        <field name="view_mode">list,form,kanban</field>
        <field name="search_view_id" ref="view_tenant_search"/>
    </record>   
</odoo>