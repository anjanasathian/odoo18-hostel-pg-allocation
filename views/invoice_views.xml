<?xml version="1.0" encoding="utf-8"?>
<odoo>
 
        <!-- Invoice List View -->
    <record id="view_hostel_invoice_list" model="ir.ui.view">
        <field name="name">hostel.invoice.list</field>
        <field name="model">hostel.invoice</field>
        <field name="arch" type="xml">
            <list string="Hostel Invoices">
                <field name="invoice_number"/>
                <field name="tenant_id"/>
                <field name="name"/>
                <field name="room_id"/>
                <field name="total_days"/>  
                <field name="amount_total"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <!-- Invoice Form View -->
    <record id="view_hostel_invoice_form" model="ir.ui.view">
        <field name="name">hostel.invoice.form</field>
        <field name="model">hostel.invoice</field>
        <field name="arch" type="xml">
            <form string="Hostel Invoice">
                <header>
                    <button name="action_draft" string="Draft" type="object" class="btn-secondary" invisible="state == 'draft'"/>
                    <button name="action_paid" string="Paid" type="object" class="btn-primary" invisible="state == 'paid'"/>
                    <button name="action_cancel" string="Cancelled" type="object" class="btn-secondary" invisible="state == 'cancelled'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,paid,cancelled"/>
                </header>
                <sheet>
                    <group>
                        <field name="invoice_number" readonly="1"/>
                        <field name="tenant_id"/>
                        <field name="name" readonly="1"/>
                        <field name="email" readonly="1"/>
                        <field name="phone" readonly="1"/>
                        <field name="address" readonly="1"/>
                    </group>
                    <group>
                        <field name="room_id" readonly="1"/>
                        <field name="bed_id" readonly="1"/>
                        <field name="check_in_date" readonly="1"/>
                        <field name="check_out_date" readonly="1"/>
                        <field name="billing_from"/>
                        <field name="billing_to"/>
                        <field name="total_days" readonly="1"/>
                        <field name="daily_rate"/>  
                    </group>
                    <group>
                        <field name="amount_total" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

<!-- Action Hostel Invoice  -->
    <record id="action_hostel_invoice" model="ir.actions.act_window">
        <field name="name">Hostel Invoices</field>
        <field name="res_model">hostel.invoice</field>
        <field name="view_mode">list,form</field>
    </record>   

</odoo>