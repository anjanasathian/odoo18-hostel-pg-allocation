<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Hostel Category List View -->
    <record id="view_hostel_category_list" model="ir.ui.view">
        <field name="name">hostel.category.list</field>
        <field name="model">hostel.category</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="code"/>
                <field name="description"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- Hostel Category Form View -->
    <record id="view_hostel_category_form" model="ir.ui.view">
        <field name="name">hostel.category.form</field>
        <field name="model">hostel.category</field>
        <field name="arch" type="xml">
            <form string="Hostel Category">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="color" widget="color_picker"/>
                        </group>
                        <group>
                            <field name="active"/>
                        </group>
                    </group>
                    <group>
                        <field name="description" placeholder="Describe this category..."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Hostel Category Search View -->
    <record id="view_hostel_category_search" model="ir.ui.view">
        <field name="name">hostel.category.search</field>
        <field name="model">hostel.category</field>
        <field name="arch" type="xml">
            <search string="Search Categories">
                <field name="name" string="Category Name"/>
                <filter string="Active" name="active" domain="[('active','=',True)]"/>
                <filter string="Archived" name="archived" domain="[('active','=',False)]"/>
            </search>
        </field>
    </record>

    <!-- Hostel Category Action -->
    <record id="action_hostel_category" model="ir.actions.act_window">
        <field name="name">Hostel Categories</field>
        <field name="res_model">hostel.category</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_hostel_category_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first hostel category!
            </p>
        </field>
    </record>

</odoo>
