<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Form View for Hostel Bed -->
    <record id="hostel_bed_form_view" model="ir.ui.view">
        <field name="name">hostel.bed.form</field>
        <field name="model">hostel.bed</field>
        <field name="arch" type="xml">
            <form string="Hostel Bed">
                <sheet>
                    <group>
                        <group>
                            <field name="name" readonly="1"/>
                            <field name="room_id"/>
                            <field name="status"/>
                        </group>
                        <group>
                            <field name="tenant_id"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>   

    <!-- List View for Hostel Bed -->
    <record id="hostel_bed_list_view" model="ir.ui.view">
        <field name="name">hostel.bed.list</field>
        <field name="model">hostel.bed</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="room_id"/>
                <field name="status"/>
                <field name="tenant_id"/>
            </list>
        </field>
    </record> 

   <!-- Action for Hostel Bed -->
    <record id="hostel_bed_action" model="ir.actions.act_window">
        <field name="name">Hostel Beds</field>
        <field name="res_model">hostel.bed</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>