<?xml version="1.0" encoding="utf-8"?>
<odoo>
        <!-- Hostel List View  -->
    <record id="view_hostel_list" model="ir.ui.view">
        <field name="name">hostel.hostel.list</field>
        <field name="model">hostel.hostel</field>
        <field name="arch" type="xml">

            <list>
                <field name="name"/>
                <field name="category_id"/>
                <field name="phone"/>
                <field name="total_floors"/>
                <field name="room_count"/>
                <field name="full_room_count"/>
                <field name="available_room_count"/>
            </list>

        </field>
    </record>
     
    <!-- Hostel Form View  -->
    <record id="view_hostel_form" model="ir.ui.view">
        <field name="name">hostel.hostel.form</field>
        <field name="model">hostel.hostel</field>
        <field name="arch" type="xml">              
            <form string="Hostel">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="category_id"/>
                        <field name="phone"/>
                        <field name="total_floors"/>
                    </group>
                    <notebook>
                        <page string="Rooms">
                            <field name="room_ids">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="floor"/>
                                    <field name="capacity"/>
                                    <field name="status"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>   

    <!-- Hostel Kanban View   -->

    <record id="view_hostel_kanban" model="ir.ui.view">
        <field name="name">hostel.hostel.kanban</field>
        <field name="model">hostel.hostel</field>
        <field name="arch" type="xml">
            <kanban>
                <field name="name"/>
                <field name="phone"/>
                <field name="total_floors"/>
                <field name="room_count"/>
                <field name="full_room_count"/>
                <field name="available_room_count"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click o_kanban_record">
                            <div class="o_kanban_record_title">
                                <strong><field name="name"/></strong>
                            </div>
                            <div><span>Phone: </span><field name="phone"/></div>
                            <div><span>Total Floors: </span><field name="total_floors"/></div>
                            <div><span>Rooms: </span><field name="room_count"/></div>
                            <div><span>Full: </span><field name="full_room_count"/></div>
                            <div><span>Available: </span><field name="available_room_count"/></div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>           
        <!-- ACTION -->
    <record id="action_hostel" model="ir.actions.act_window">
        <field name="name">Hostels</field>
        <field name="res_model">hostel.hostel</field>
        <field name="view_mode">list,form,kanban</field>
    </record>

</odoo>
